# ── Docker Compose host bindings ────────────────────────────────────────────
SERVER_IP=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ── Backend (Django) ─────────────────────────────────────────────────────────
# Generate: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,backend:8000,testserver
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# SQLite is used locally when DATABASE_URL is omitted.
# Docker Compose sets this automatically via docker-compose.yml.
# DATABASE_URL=postgres://lims:lims@localhost:5432/lims

# Tasks run synchronously (no Redis/Celery needed for local dev or Docker Compose)
CELERY_TASK_ALWAYS_EAGER=True

# JWT_SIGNING_KEY=your-jwt-signing-key-here
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Email / dispatch-failure notifications ───────────────────────────────────
# Probability (0..1) that a finishing simulated dispatch fails with an
# execution exception instead of completing. Default 0.15.
# DISPATCH_FAILURE_RATE=0.15
# Comma-separated recipients for failure alerts. Empty = no email sent.
# DISPATCH_FAILURE_NOTIFY_EMAILS=lab-manager@example.com,ops@example.com
# Dev default backend prints emails to stdout. For real delivery, set:
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.example.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=lims@example.com

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
# Server-side proxy target. In Docker Compose this is set to http://backend:8000.
# For local dev (npm run dev), point to the running Django server.
LIMS_BACKEND_URL=http://localhost:8000
