# generate your key by `uv run python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Container startup controls. Demo seeds default to disabled in the image so
# deploys do not overwrite equipment, recipe, experiment-type, or demo-user edits.
# RUN_MIGRATIONS=1
# RUN_DEMO_SEEDS=0
# JWT_SIGNING_KEY=your-jwt-signing-key-here
# JWT_ACCESS_TOKEN_LIFETIME_MINUTES=30
# JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# --- Observability (LGTM stack on Railway) ---
# Prometheus middleware + /metrics endpoint (default: True)
# METRICS_ENABLED=True
# Wrap DB engine with django-prometheus for query metrics (default: False)
# METRICS_DB_INSTRUMENT=False
# OpenTelemetry → Tempo. Set to enable tracing.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo.railway.internal:4317
# OTEL_SERVICE_NAME=lims-backend
# Loki push URL. Set to enable direct log push (skip if you have a log shipper).
# LOKI_URL=http://loki.railway.internal:3100/loki/api/v1/push
# LOKI_LOG_LEVEL=INFO
# DJANGO_LOG_LEVEL=INFO
